# ── Django ────────────────────────────────────────────────────────────────────
# Generate a new key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-in-production

DEBUG=false

# Comma-separated — add your Hetzner server IP or domain here
ALLOWED_HOSTS=your-domain.com,your-server-ip

# Comma-separated allowed origins for the Flutter apps (leave empty to deny all)
CORS_ALLOWED_ORIGINS=

# ── Database ──────────────────────────────────────────────────────────────────
DB_NAME=wanderguard
DB_USER=wanderguard
DB_PASSWORD=change-me-strong-password
DB_HOST=db
DB_PORT=5432

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Firebase ──────────────────────────────────────────────────────────────────
# Mount firebase-credentials.json into the container, then set the path here
FIREBASE_CREDENTIALS_PATH=/app/firebase-credentials.json

# ── TLS / Let's Encrypt ───────────────────────────────────────────────────────
DOMAIN=your-domain.com
CERTBOT_EMAIL=your@email.com
